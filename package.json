{
  "name": "action-name",
  "version": "0.0.0",
  "type": "module",
  "description": "Action description",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && ncc build lib/acquire.js --out dist/acquire --minify && ncc build lib/release.js --out dist/release --minify",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "test": "vitest run",
    "readme": "npx action-docs -u && prettier --write README.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freckle/aws-s3-lock-action.git"
  },
  "author": "Freckle",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@aws-sdk/client-s3": "^3.1027.0",
    "@aws-sdk/lib-storage": "^3.1027.0",
    "ansi-styles": "^6.2.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@actions/glob": "^0.6.1",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/types": "^16.0.0",
    "@types/ansi-styles": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/uuid": "^11.0.0",
    "@vercel/ncc": "^0.38.4",
    "action-docs": "^2.5.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
